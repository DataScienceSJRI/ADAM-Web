# Copy this file to .env and fill in values for the environment you are running.
# Do not commit real secrets.

# Supabase backend credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Frontend/Vercel public Supabase credentials
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Backend CORS. For local Docker dev, docker-compose.dev.yml overrides this.
# For production, set this to the Vercel frontend domain.
# ALLOWED_ORIGINS=https://adam.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Used by the Next.js API proxy.
# Local Docker dev overrides this to http://backend:8000.
# On Vercel, set this to your public backend URL, for example:
# BACKEND_URL=https://datatools.sjri.res.in/ADAM
BACKEND_URL=http://localhost:8000
